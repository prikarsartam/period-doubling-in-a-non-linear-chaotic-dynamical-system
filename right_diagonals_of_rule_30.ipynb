     "output_type": "execute_result"
    }
   ],
   "source": [
    "def lfloor(m):\n",
    "    if m%2==0:\n",
    "        return int(m/2)\n",
    "    else:\n",
    "        return int((m-1)/2)\n",
    "\n",
    "# lfloor(11)\n",
    "\n",
    "def x0_t0(m):\n",
    "    n = lfloor(m)                # n = floor(m/2)\n",
    "    \n",
    "    if m % 2 == 0:                # even m = 2n\n",
    "        x0 = -n\n",
    "    else:                         # odd m = 2n+1\n",
    "        x0 = -(n + 1)\n",
    "    t0 = n - 1\n",
    "    return (x0, t0)\n",
    "\n",
    "x0_t0(7)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bad4891d",
   "metadata": {},
   "source": [
    "---\n",
    "\n",
    "#### the following definition of the *right diagonals* $R_m(n \\in \\mathbb{N})$ of the rule 30 cellular automata, follows the notation by M. Brunnbauer from his article : [Diagonals in elementary cellular automaton 30](https://brunni.de/findings30/)\n",
    "\n",
    "- This article contains a clear mechanism of the doubling of these information-preserving right diagonals, unlike the left diagonals which loose information due to the lack of right-bijectivity in rule 30.\n",
    "\n",
    "- Notice that $f(l,c,r)=(l+c+r+cr) \\mod  2, \\ \\forall \\ l,c,r \\in \\mathbb{N}.$\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "47c30038",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "--------------------------------------------------------------------------------------\n",
      "right-diagonal starting at (t= 1, x= -2) with length= 1024\n",
      "--------------------------------------------------------------------------------------\n",
      "\n",
      "period = 4\n",
      "preperiod = 0\n",
      "periodic word = (0, 1, 1, 0)\n"
     ]
    }
   ],
   "source": [
    "def R(m, length=2**10):\n",
    "    x0=x0_t0(m)[0]\n",
    "    t0=x0_t0(m)[1]\n",
    "    periodicity_analysis(t0, x0, length, \"right\")\n",
    "\n",
    "R(4)        "
   ]
  },
